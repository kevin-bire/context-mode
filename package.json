{
  "name": "context-mode",
  "displayName": "Context Mode",
  "description": "A VS Code extension that helps you manage and switch between different context configurations for your projects.",
  "version": "1.0.0",
  "publisher": "context-mode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mksglu/context-mode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "context",
    "mode",
    "workspace",
    "configuration",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "context-mode.activate",
        "title": "Context Mode: Activate"
      },
      {
        "command": "context-mode.deactivate",
        "title": "Context Mode: Deactivate"
      },
      {
        "command": "context-mode.switchContext",
        "title": "Context Mode: Switch Context"
      },
      {
        "command": "context-mode.createContext",
        "title": "Context Mode: Create New Context"
      }
    ],
    "configuration": {
      "title": "Context Mode",
      "properties": {
        "contextMode.defaultContext": {
          "type": "string",
          "default": "default",
          "description": "The default context to activate on workspace open."
        },
        "contextMode.autoActivate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically activate context mode when opening a workspace."
        },
        "contextMode.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show the current context in the status bar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.1.6"
  }
}
